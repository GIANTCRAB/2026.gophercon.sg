---
interface Props {
  active: "conference" | "workshops";
}

const { active } = Astro.props;
---

<div style="display: flex; justify-content: center; gap: 0.5rem; margin-bottom: 2.5rem; flex-wrap: wrap;">
  <a href="/schedule" class:list={["schedule-tab", active === "conference" && "active"]}>Conference</a>
  <a href="/workshops" class:list={["schedule-tab", active === "workshops" && "active"]}>Workshops</a>
</div>

<style>
  .schedule-tab {
    padding: 0.65rem 1.5rem;
    border-radius: 50px;
    border: 2px solid #d0d5dd;
    background: #fff;
    color: #667085;
    font-weight: 600;
    font-size: 0.95rem;
    transition: all 0.2s;
    text-decoration: none;
  }

  .schedule-tab:hover {
    border-color: #98a2b3;
    color: var(--color-body-text);
  }

  .schedule-tab.active {
    border-color: var(--color-brand-blue);
    background: var(--color-brand-blue);
    color: #fff;
  }
</style>
