---
import ComingSoon from "@/components/ComingSoon.astro";
import CodeOfConduct from "@/components/index/CodeOfConduct.astro";
import Hero from "@/components/index/Hero.astro";
import SpeakerCard from "@/components/index/SpeakerCard.astro";
import Sponsors from "@/components/index/Sponsors.astro";
import Tickets from "@/components/index/Tickets.astro";
import VenueInfo from "@/components/index/VenueInfo.astro";
import { isArchived, isLineupConfirmed } from "@/config";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { speakers } from "@/lib/data";
import { speakerImages } from "@/lib/images";
---

<BaseLayout>
  {isArchived && (
    <div style="background: var(--color-brand-blue); color: #fff; text-align: center; padding: 1rem; font-weight: 600; font-size: 1.1rem;">
      Thank you for joining us at GopherCon Singapore 2026!
    </div>
  )}

  <Hero />
  <VenueInfo />

  <section class="speakers" style="margin-bottom: 4rem;">
    <div class="container text-center">
      <h2 class="pt-8 mb-12 text-center md:pt-40 md:mb-24">Our Speakers</h2>

      {speakers.length > 0 ? (
        <>
          <ul class="speakers-flex">
            {speakers.map((speaker) => (
              <SpeakerCard speaker={speaker} imageMap={speakerImages} />
            ))}
          </ul>
          {!isLineupConfirmed && (
            <p style="color: #555; font-size: 1.1rem; margin-top: -1rem;"><em>More speakers will be announced as they are confirmed.</em></p>
          )}
        </>
      ) : (
        <ComingSoon message="Speaker lineup" />
      )}
    </div>
  </section>

  <Tickets />
  <CodeOfConduct />
  <Sponsors />
</BaseLayout>
