---
import { Image } from "astro:assets";
import { type ImageMap, findSpeakerImage } from "@/lib/images";
import type { Workshop } from "@/types";
import { Icon } from "astro-icon/components";
import { marked } from "marked";

interface Props {
  workshop: Workshop;
  speakerImageMap: ImageMap;
}

const { workshop, speakerImageMap } = Astro.props;

// Split description at first h4 heading for progressive disclosure
const h4Index = workshop.description.indexOf("\n####");
const hasSyllabus = h4Index > 0;
const overviewMd = hasSyllabus
  ? workshop.description.substring(0, h4Index).trim()
  : workshop.description;
const syllabusMd = hasSyllabus
  ? workshop.description.substring(h4Index).trim()
  : "";

const overviewHtml = marked.parse(overviewMd);
const syllabusHtml = hasSyllabus ? marked.parse(syllabusMd) : "";
const speakerBioHtml = marked.parse(workshop.speakerBio);
const prerequisitesHtml = workshop.prerequisites
  ? marked.parse(workshop.prerequisites)
  : "";
const venueHtml = marked.parse(workshop.venue);

const speakerImg = findSpeakerImage(speakerImageMap, workshop.speakerImage);

// Resolve team member images
const teamMembers = (workshop.teamMembers ?? []).map((member) => ({
  ...member,
  resolvedImage: member.image
    ? findSpeakerImage(speakerImageMap, member.image)
    : null,
  bioHtml: marked.parse(member.bio),
}));
const hasTeam = teamMembers.length > 0;
---

<article id={workshop.id} class="bg-white border border-gray-200 rounded-2xl overflow-hidden shadow-sm scroll-mt-40 transition-shadow duration-200 hover:shadow-lg">
  <div class="flex flex-col items-center text-center md:flex-row md:items-start md:text-left gap-5 p-8 bg-gradient-to-br from-[#f0fdfa] to-[#ecfeff] border-b border-gray-200">
    {hasTeam ? (
      <div class="flex -space-x-2.5 shrink-0">
        {teamMembers.map((member, i) => (
          <div
            class="w-11 h-11 rounded-full overflow-hidden border-2 border-white shadow-sm"
            style={`z-index: ${teamMembers.length - i}; position: relative;`}
            title={member.name}
          >
            {member.resolvedImage ? (
              <Image
                src={member.resolvedImage}
                alt={member.name}
                width={48}
                height={48}
                class="w-full h-full object-cover"
              />
            ) : (
              <div class="w-full h-full bg-gradient-to-br from-brand-blue to-[#0e7490] flex items-center justify-center text-white text-sm font-bold">
                {member.name.charAt(0)}
              </div>
            )}
          </div>
        ))}
      </div>
    ) : (
      <div class="w-20 h-20 rounded-full overflow-hidden shrink-0 border-[3px] border-brand-blue">
        {speakerImg ? (
          <Image
            src={speakerImg}
            alt={workshop.speaker}
            width={80}
            height={80}
            class="w-full h-full object-cover"
          />
        ) : (
          <div class="w-full h-full bg-gradient-to-br from-brand-blue to-[#0e7490] flex items-center justify-center text-white text-[1.75rem] font-bold">
            {workshop.speaker.charAt(0)}
          </div>
        )}
      </div>
    )}
    <div>
      <h2 class="text-2xl font-bold leading-[1.3] mb-1 text-body-text">
        {workshop.title}
        <span class="copy-link-wrapper" style="vertical-align: middle;">
          <button
            type="button"
            class="copy-link"
            data-href={`/workshops#${workshop.id}`}
            aria-label="Copy link to this workshop"
          >
            <Icon name="fa:link" class="w-3.5 h-3.5" />
          </button>
          <span class="copy-link-tooltip" aria-live="polite">Copied!</span>
        </span>
      </h2>
      <div class="text-[0.95rem] text-[#555] mb-2 leading-[1.6]">
        by{" "}
        <a href={workshop.speakerLink} class="text-link-blue font-semibold">{workshop.speaker}</a>
        {workshop.speakerSocialUrl && (
          <a
            href={workshop.speakerSocialUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center ml-2 text-link-blue"
          >
            <Icon name="fa:twitter" class="w-3.5 h-3.5" />
          </a>
        )}
      </div>
      <div class="flex gap-4 text-sm text-[#0e7490] font-semibold flex-wrap justify-center md:justify-start">
        <span class="inline-flex items-center gap-1.5"><Icon name="fa:calendar" class="w-3.5 h-3.5" />{workshop.date}</span>
        <span class="inline-flex items-center gap-1.5"><Icon name="fa:clock-o" class="w-3.5 h-3.5" />{workshop.time}</span>
      </div>
    </div>
  </div>

  <div class="workshop-body p-8">
    <div class="workshop-overview text-base leading-[1.8] text-gray-700" set:html={overviewHtml} />

    {syllabusHtml && (
      <div class="border border-gray-200 rounded-xl my-6 overflow-hidden">
        <h3 class="px-5 py-4 font-semibold text-[1.05rem] bg-gray-50 text-body-text mb-0 border-b border-gray-200">Full Curriculum</h3>
        <div class="section-content p-5 leading-[1.7] text-gray-700" set:html={syllabusHtml} />
      </div>
    )}

    {prerequisitesHtml && (
      <div class="prerequisites bg-[#f0f9ff] border-l-4 border-brand-blue py-4 px-6 rounded-r-lg my-6">
        <h4 style="margin-top: 0;">Prerequisites</h4>
        <div set:html={prerequisitesHtml} />
      </div>
    )}

    <div class="border border-gray-200 rounded-xl my-6 overflow-hidden">
      <h3 class="px-5 py-4 font-semibold text-[1.05rem] bg-gray-50 text-body-text mb-0 border-b border-gray-200">
        {hasTeam ? "Meet the Team" : "About the Instructor"}
      </h3>
      <div class="section-content p-5 leading-[1.7] text-gray-700">
        {hasTeam ? (
          <>
            <div class="team-bio mb-6" set:html={speakerBioHtml} />
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
              {teamMembers.map((member) => (
                <div class="team-member flex items-start gap-3.5 p-3 rounded-xl bg-[#f8fffe] border border-gray-100">
                  <div class="w-14 h-14 rounded-full overflow-hidden shrink-0 border-2 border-brand-blue">
                    {member.resolvedImage ? (
                      <Image
                        src={member.resolvedImage}
                        alt={member.name}
                        width={64}
                        height={64}
                        class="w-full h-full object-cover"
                      />
                    ) : (
                      <div class="w-full h-full bg-gradient-to-br from-brand-blue to-[#0e7490] flex items-center justify-center text-white text-lg font-bold">
                        {member.name.charAt(0)}
                      </div>
                    )}
                  </div>
                  <div class="min-w-0">
                    <h4 class="font-semibold text-body-text text-[0.9rem] mb-1 mt-0">{member.name}</h4>
                    <div class="team-member-bio text-[0.82rem] text-gray-600 leading-[1.55]" set:html={member.bioHtml} />
                  </div>
                </div>
              ))}
            </div>
          </>
        ) : (
          <div class="flex flex-col items-center text-center md:flex-row md:items-start md:text-left gap-6">
            {speakerImg && (
              <div class="w-[100px] h-[100px] rounded-full overflow-hidden shrink-0 border-2 border-brand-blue">
                <Image
                  src={speakerImg}
                  alt={workshop.speaker}
                  width={120}
                  height={120}
                  class="w-full h-full object-cover"
                />
              </div>
            )}
            <div set:html={speakerBioHtml} />
          </div>
        )}
      </div>
    </div>

    <div class="border-t border-gray-100 pt-5 mt-6 flex flex-col gap-2">
      <div class="venue-info flex items-center gap-2 text-[0.95rem] text-[#555]">
        <Icon name="fa:map-marker" class="w-4 h-4 text-brand-red shrink-0" />
        <div set:html={venueHtml} />
      </div>
      {workshop.venueRegistration && (
        <p class="text-sm text-[#666] mb-0">({workshop.venueRegistration})</p>
      )}
      {workshop.venueMapUrl && (
        <a
          href={workshop.venueMapUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-link-blue"
        >
          View on map →
        </a>
      )}
      {workshop.additional && (
        <p class="flex items-center gap-2 text-sm text-[#666] mb-0">
          <Icon name="fa:info-circle" class="w-4 h-4 text-brand-blue shrink-0" />
          {workshop.additional}
        </p>
      )}
    </div>
  </div>
</article>

<style>
  /* Scoped styles for markdown content rendered via set:html */
  .workshop-body :global(ul) {
    list-style: disc;
    padding-left: 1.5rem;
  }

  .workshop-overview :global(p:last-child) {
    margin-bottom: 0;
  }

  .section-content :global(h4) {
    margin-top: 1.5rem;
  }

  .section-content :global(h4:first-child) {
    margin-top: 0;
  }

  .section-content :global(h5) {
    font-size: 1rem;
    font-weight: 600;
    margin-top: 1.25rem;
    margin-bottom: 0.5rem;
    color: #0e7490;
  }

  .section-content :global(li) {
    margin-bottom: 0.25rem;
  }

  .section-content :global(p) {
    margin-bottom: 0.75rem;
  }

  .venue-info :global(p) {
    margin-bottom: 0;
  }

  .prerequisites :global(ul) {
    list-style: disc;
    padding-left: 1.5rem;
  }

  .team-bio :global(p) {
    margin-bottom: 0.5rem;
  }

  .team-bio :global(p:last-child) {
    margin-bottom: 0;
  }

  .team-member-bio :global(p) {
    margin-bottom: 0;
  }
</style>
