---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title?: string;
  description?: string;
  redirectURL: string;
}

const { title, description, redirectURL } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <meta http-equiv="refresh" content={`0; url=${redirectURL}`} slot="head" />
  <slot />
</BaseLayout>
