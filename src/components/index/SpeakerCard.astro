---
import { Image } from "astro:assets";
import { type ImageMap, findSpeakerImage } from "@/lib/images";
import type { Speaker } from "@/types";

interface Props {
  speaker: Speaker;
  imageMap: ImageMap;
}

const { speaker, imageMap } = Astro.props;
const speakerImg = findSpeakerImage(imageMap, speaker.image);
---

<li class="speaker-card">
  <a href={`/speakers#${speaker.id}`} style="text-decoration: none; color: inherit;">
    {speakerImg ? (
      <Image
        src={speakerImg}
        alt={speaker.name}
        width={120}
        height={120}
        style="width: 100%; margin: 0 auto 0.5rem; display: block;"
      />
    ) : (
      <div class="speaker-card-placeholder">{speaker.name.charAt(0)}</div>
    )}
    <h3 class="speaker-card-name">{speaker.name}</h3>
    {speaker.company && (
      <div class="speaker-card-company">{speaker.company}</div>
    )}
  </a>
</li>

<style>
  .speaker-card {
    text-align: center;
    list-style: none;
  }

  .speaker-card-name {
    font-size: 0.8rem;
    font-weight: 500;
    margin-bottom: 0.15rem;
    font-family: var(--font-body);
    line-height: 1.2;
  }

  .speaker-card-company {
    font-size: 0.7rem;
    color: #666;
    line-height: 1.2;
  }

  .speaker-card-placeholder {
    width: 100%;
    aspect-ratio: 1;
    border-radius: 50%;
    background: #e0e7ee;
    color: #667085;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    font-weight: 700;
    margin: 0 auto 0.5rem;
  }
</style>
