---
import { Image } from "astro:assets";
import { type ImageMap, findSpeakerImage } from "@/lib/images";
import { md } from "@/lib/markdown";
import type { Speaker } from "@/types";
import { Icon } from "astro-icon/components";

interface Props {
  speaker: Speaker;
  imageMap: ImageMap;
}

const { speaker, imageMap } = Astro.props;
const descriptionHtml = md(speaker.bio);
const speakerImg = speaker.image
  ? findSpeakerImage(imageMap, speaker.image)
  : null;

function getSocialHandle(url: string): string {
  try {
    const pathname = new URL(url).pathname;
    const handle = pathname.split("/").filter(Boolean).pop();
    return handle ? `@${handle}` : url;
  } catch {
    return url;
  }
}
---

<article id={speaker.id} class="speaker-row">
  <div class="speaker-head">
    <div class:list={["speaker-photo", speaker.keynote && "speaker-photo-keynote"]}>
      {speakerImg ? (
        <Image
          src={speakerImg}
          alt={speaker.name}
          width={80}
          height={80}
          class="w-full h-full object-cover"
        />
      ) : (
        <div class="speaker-photo-placeholder" aria-hidden="true">{speaker.name.charAt(0)}</div>
      )}
    </div>
    <div class="speaker-info">
      {speaker.keynote && (
        <span class="speaker-badge">Keynote Speaker</span>
      )}
      <div class="speaker-title-row">
        <h3 class="speaker-name">{speaker.name}</h3>
        <span class="copy-link-wrapper">
          <button
            type="button"
            class="copy-link"
            data-href={`/speakers#${speaker.id}`}
            aria-label="Copy link to this speaker"
          >
            <Icon name="fa:link" class="w-3.5 h-3.5" />
          </button>
          <span class="copy-link-tooltip" aria-live="polite">Copied!</span>
        </span>
      </div>
      {speaker.company && (
        <div class="speaker-company">{speaker.company}</div>
      )}

      {speaker.topicTitle && (
        <a href={speaker.topicLink} class="speaker-topic">
          {speaker.topicTitle} &rarr;
        </a>
      )}

      <div class="speaker-bio">
        <div set:html={descriptionHtml} />
      </div>

      {speaker.socialUrl && (
        <a
          href={speaker.socialUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="speaker-social"
        >
          {getSocialHandle(speaker.socialUrl)} &rarr;
        </a>
      )}
      {speaker.url && (
        <a
          href={speaker.url}
          target="_blank"
          rel="noopener noreferrer"
          class="speaker-social"
        >
          Website &rarr;
        </a>
      )}
    </div>
  </div>
</article>

<style>
  .speaker-row {
    padding: 1.5rem 0.25rem;
    border-bottom: 1px solid #e5e7eb;
    /* Clear sticky header (85px) + sticky mosaic nav (~80px) */
    scroll-margin-top: calc(var(--header-height, 85px) + 6rem);
  }
  .speaker-row:last-child {
    border-bottom: none;
  }

  .speaker-head {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
  }

  .speaker-photo {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    border: 3px solid var(--color-brand-blue);
  }
  .speaker-photo-keynote {
    border-color: var(--color-brand-red);
  }

  .speaker-info {
    flex: 1;
    min-width: 0;
  }

  .speaker-badge {
    display: inline-block;
    color: var(--color-brand-red);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: 0.15rem;
  }

  .speaker-title-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .speaker-name {
    font-size: 1.15rem;
    font-weight: 700;
    margin: 0;
    line-height: 1.3;
  }

  .speaker-company {
    color: #888;
    font-size: 0.9rem;
    margin-top: 0.05rem;
  }

  .speaker-topic {
    display: block;
    color: #007d9c;
    font-weight: 600;
    font-size: 0.95rem;
    text-decoration: none;
    margin: 0.45rem 0 0.55rem;
  }
  .speaker-topic:hover {
    text-decoration: underline;
  }

  .speaker-bio {
    color: #4b5563;
    font-size: 0.9rem;
    line-height: 1.65;
  }
  .speaker-bio :global(p) {
    margin: 0 0 0.5rem;
  }
  .speaker-bio :global(p:last-child) {
    margin-bottom: 0;
  }

  .speaker-social {
    display: inline-block;
    margin-top: 0.6rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-brand-blue);
    text-decoration: none;
  }
  .speaker-social:hover {
    text-decoration: underline;
  }

  @media (max-width: 480px) {
    .speaker-photo { width: 64px; height: 64px; }
  }

  .speaker-photo-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #e0e7ee;
    color: #667085;
    font-weight: 700;
    font-size: 2rem;
  }
</style>
