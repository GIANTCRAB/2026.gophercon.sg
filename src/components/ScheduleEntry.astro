---
import { Image } from "astro:assets";
import { type ImageMap, findSpeakerImage } from "@/lib/images";
import type { ScheduleEntry } from "@/types";
import { Icon } from "astro-icon/components";
import { marked } from "marked";

interface Props {
  entry: ScheduleEntry;
  imageMap: ImageMap;
}

const { entry, imageMap } = Astro.props;

const descriptionHtml = entry.description
  ? marked.parse(entry.description)
  : "";
const isBreakOrMeta = entry.type === "break" || entry.type === "meta";
---

<div
  id={entry.id}
  class:list={[
    "timeline-entry",
    `timeline-entry-${entry.type}`,
  ]}
>
  <div class="timeline-time">{entry.time}</div>

  {isBreakOrMeta ? (
    <div class="timeline-break-pill">
      {entry.title}{entry.description ? ` — ${entry.description}` : ""}
    </div>
  ) : (
    <>
      <div style="display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 0.25rem;">
        <div class="timeline-title">{entry.title}</div>
        <span class="copy-link-wrapper">
          <button
            type="button"
            class="copy-link"
            data-href={`/schedule#${entry.id}`}
            aria-label="Copy link to this session"
          >
            <Icon name="fa:link" class="w-3.5 h-3.5" />
          </button>
          <span class="copy-link-tooltip" aria-live="polite">Copied!</span>
        </span>
      </div>

      {entry.speakers.map((speaker) => {
        const img = speaker.image ? findSpeakerImage(imageMap, speaker.image) : null;
        return (
          <div class="timeline-speaker-inline">
            {img && (
              <div class="timeline-speaker-thumb">
                {speaker.link ? (
                  <a href={speaker.link} style="display: block; width: 100%; height: 100%;">
                    <Image
                      src={img}
                      alt={speaker.name}
                      width={32}
                      height={32}
                      class="w-full h-full object-cover"
                    />
                  </a>
                ) : (
                  <Image
                    src={img}
                    alt={speaker.name}
                    width={32}
                    height={32}
                    class="w-full h-full object-cover"
                  />
                )}
              </div>
            )}
            {speaker.link ? (
              <a href={speaker.link} style="font-size: 0.9rem; color: #555;">{speaker.name}</a>
            ) : (
              <span style="font-size: 0.9rem; color: #555;">{speaker.name}</span>
            )}
          </div>
        );
      })}

      {descriptionHtml && (
        <div class="timeline-desc" set:html={descriptionHtml} />
      )}

      {entry.recordingUrl && (
        <a
          href={entry.recordingUrl}
          target="_blank"
          rel="noopener noreferrer"
          style="display: inline-block; background: var(--color-brand-blue); color: #fff; padding: 0.25rem 0.75rem; border-radius: 1rem; font-size: 0.875rem; text-decoration: none; margin-top: 0.5rem;"
        >
          Watch Recording ▶
        </a>
      )}
    </>
  )}
</div>
