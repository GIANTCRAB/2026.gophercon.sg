---
import { content } from "@/lib/data";
import { marked } from "marked";
const heroConfig = content.hero;

const practicalInfoHtml = heroConfig.practicalInfo
  ? marked.parse(heroConfig.practicalInfo)
  : "";
---

<section class="py-8 md:py-16 bg-brand-blue font-display text-white antialiased text-center md:text-left">
  <div class="container">
    <div class="venue-grid">
      <div class="venue-col venue-col-left">
        <h2 class="venue-heading" style="margin-bottom: 1rem; font-family: var(--font-display);">Pre-conference Workshops</h2>
        <div class="venue-details">
          {heroConfig.workshopDates}<br />
          <a
            href={heroConfig.workshopVenueUrl}
            target="_blank"
            rel="noopener noreferrer"
            style="color: #fff;"
          >
            {heroConfig.workshopVenue}
          </a>
        </div>
      </div>

      <div class="venue-col">
        <h2 style="margin-bottom: 1rem; font-family: var(--font-display);">Conference</h2>
        <div class="venue-details">
          {heroConfig.conferenceDates}<br />
          <a
            href={heroConfig.conferenceVenueUrl}
            target="_blank"
            rel="noopener noreferrer"
            style="color: #fff;"
          >
            {heroConfig.conferenceVenue}
          </a>
        </div>
      </div>
    </div>

    {practicalInfoHtml && (
      <div set:html={practicalInfoHtml} style="margin-top: 1.5rem;" />
    )}
  </div>
</section>

<style>
  .venue-grid {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  @media (min-width: 768px) {
    .venue-grid {
      flex-direction: row;
    }
  }

  .venue-col {
    flex: 1;
  }

  @media (min-width: 768px) {
    .venue-grid {
      justify-content: center;
    }

    .venue-col {
      flex: 1 1 0;
      max-width: 50%;
    }

    .venue-col-left {
      border-right: 1px solid #fff;
      padding-right: 3rem;
      text-align: right;
    }

    .venue-col:not(.venue-col-left) {
      padding-left: 3rem;
      text-align: left;
    }
  }

  .venue-heading {
    word-wrap: break-word;
    overflow-wrap: break-word;
  }

  @media (min-width: 768px) {
    .venue-heading {
      white-space: nowrap;
    }
  }

  .venue-details {
    font-size: 1.5rem;
    line-height: 1.25;
  }

  @media (min-width: 768px) {
    .venue-details {
      font-size: 2rem;
    }
  }
</style>
